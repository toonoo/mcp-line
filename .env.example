# Required: Channel Access Token จาก LINE Developers Console
# วิธีหา: https://developers.line.biz/console/ → เลือก Channel → Messaging API → Channel access token
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Optional: LINE userId ของผู้รับ default สำหรับ send_text และ send_image
# วิธีหา userId: ส่งข้อความหา bot แล้วดู webhook payload (source.userId)
# หรือใช้ LINE Developers Console → Messaging API → Your user ID
LINE_DEFAULT_USER_ID=
